PORT=5000

# MongoDB Atlas connection string (get from cloud.mongodb.com → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/klypup

# Any long random string — used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_string

# OpenAI API key (get from platform.openai.com)
OPENAI_API_KEY=sk-...

# Use gpt-4o-mini to keep costs low during dev, swap to gpt-4o for demo
OPENAI_MODEL=gpt-4o-mini

# ChromaDB URL — use http://chromadb:8000 inside Docker, http://localhost:8000 for local dev
CHROMADB_URL=http://chromadb:8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
